# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# SQLite WAL bus runtime artifacts
*.db
*.db-journal
*.db-wal
*.db-shm
.bridge/

# Editors
.vscode/
.idea/
*.swp

# Node (dev-only tooling, e.g. axe audit)
node_modules/
package-lock.json

# OS
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.local
.env.*.local

# Claude Code local-only permission grants (per-worktree, not shared)
.claude/settings.local.json
# Claude Code scheduled-task runtime lockfile (per-instance, ephemeral)
.claude/scheduled_tasks.lock

# Replay reports (may contain transcript-derived path/file names).
# The directory itself is tracked so `reports/axe-*` audit artifacts
# (NFR-UI-1) commit. Specific noisy outputs are excluded by glob.
reports/cli_failures.jsonl
reports/dashboard*.log
reports/soak_*
reports/replay-*.md
reports/replay_*.md

# Local-only dev artifacts (per-session, ephemeral)
.claude/worktrees/
tmp/
tmpv2-*.log

# ADR-20: KingMode UI redesign EXPERIMENTAL spike build artifacts.
# Source under dashboard/ui-next/ is tracked; node_modules + build output are not.
dashboard/ui-next/node_modules/
dashboard/ui-next/dist/
dashboard/ui-next/.vite/
dashboard/ui-next/*.local
