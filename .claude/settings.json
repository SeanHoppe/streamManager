{
  "permissions": {
    "deny": [
      "Bash(sqlite3 *rl_episodes.db*)",
      "Bash(sqlite3 *rl_shadow.db*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hook_evaluate.py"
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/robin-bash-timeout.ps1"
          }
        ]
      }
    ]
  }
}
